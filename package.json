{
    "name": "js-backend-auth-mysql",
    "version": "1.0.0",
    "description": "Authentication system with JS and MySQL",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "dev": "cross-env NODE_ENV=development nodemon src/server.js",
        "start": "cross-env NODE_ENV=production node src/server.js",
        "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format:check": "prettier . --check",
        "format:fix": "prettier . --fix",
        "prepare": "husky"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@commitlint/cli": "^19.5.0",
        "@commitlint/config-conventional": "^19.5.0",
        "@eslint/js": "^9.14.0",
        "eslint": "^9.14.0",
        "eslint-config-prettier": "^9.1.0",
        "husky": "^9.1.6",
        "jest": "^29.7.0",
        "lint-staged": "^15.2.10",
        "nodemon": "^3.1.7",
        "prettier": "3.3.3",
        "prisma": "^7.8.0",
        "supertest": "^7.0.0"
    },
    "lint-staged": {
        "*.js": [
            "npm run lint:fix",
            "npm run format:fix"
        ]
    },
    "dependencies": {
        "@prisma/adapter-mariadb": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcrypt": "^5.1.1",
        "colorette": "^2.0.20",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "countries-and-timezones": "^3.7.2",
        "cross-env": "^7.0.3",
        "dayjs": "^1.11.13",
        "dotenv-flow": "^4.1.0",
        "express": "^4.21.1",
        "helmet": "^8.0.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "libphonenumber-js": "^1.11.14",
        "mysql2": "^3.22.3",
        "rate-limiter-flexible": "^5.0.4",
        "resend": "^4.0.1-alpha.0",
        "uuid": "^11.0.3",
        "winston": "^3.16.0"
    },
    "jest": {
        "testEnvironment": "node",
        "transform": {}
    }
