import User from '../model/userModel.js'

export default {
    connect: async () => {
        try {
            await User.sequelize.authenticate()
            // Sync models (in production, use migrations)
            await User.sequelize.sync({ alter: true })
            return User.sequelize
        } catch (error) {
            throw error
        }
    },
    findUserByEmail: (email, select = '') => {
        // Sequelize doesn't use .select() string like Mongoose
        // By default it selects all except what's excluded in model definition
        return User.findOne({ where: { email } })
    },
    findUserById: (id) => {
        return User.findByPk(id)
    },
    registerUser: (userData) => {
        return User.create(userData)
    },
    findUserByConfirmationTokenAndCode: (token, code) => {
        return User.findOne({
            where: {
                accountConfirmationToken: token,
                accountConfirmationCode: code
            }
        })
    },
    findUserByPasswordResetToken: (token) => {
        return User.findOne({
            where: {
                passwordResetToken: token
            }
        })
    },
    deleteRefreshToken: (token) => {
        return User.update(
            { refreshToken: null },
            { where: { refreshToken: token } }
        )
    },
    getRefreshTokan: (token) => {
        return User.findOne({
            where: { refreshToken: token }
        })
    }
}
