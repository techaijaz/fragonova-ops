generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  user
  admin
}

model User {
  id                         String    @id @default(uuid())
  name                       String    @db.VarChar(72)
  email                      String    @unique
  phoneIsoCode               String
  phoneCountryCode           String
  phoneInternationalNumber   String
  timezone                   String
  password                   String
  role                       Role      @default(user)
  consent                    Boolean   @default(false)
  accountConfirmationStatus  Boolean   @default(false)
  accountConfirmationToken   String
  accountConfirmationCode    String
  accountConfirmationTimestamp DateTime?
  passwordResetToken         String?
  passwordResetExpiry        BigInt?
  passwordResetLastResetAt   DateTime?
  refreshToken               String?
  lastLoginAt                DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@map("users")
}
